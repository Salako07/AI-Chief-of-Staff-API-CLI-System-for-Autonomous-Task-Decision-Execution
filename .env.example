# AI Chief of Staff - Environment Configuration

# ============================================================================
# OpenAI API Configuration
# ============================================================================
# Your OpenAI API key (required)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use for AI agents
OPENAI_MODEL=gpt-4o-mini

# Temperature for AI generation (0.0-1.0, lower = more deterministic)
OPENAI_TEMPERATURE=0.2

# ============================================================================
# Slack Integration (Optional)
# ============================================================================
# Slack incoming webhook URL for notifications
# Get webhook from: https://api.slack.com/messaging/webhooks
# Leave empty to disable Slack notifications
SLACK_WEBHOOK_URL=

# Example:
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX

# ============================================================================
# Quality Control Settings
# ============================================================================
# Minimum quality score threshold (set in code: app/services/processor.py:19)
# MIN_QUALITY_SCORE=5

# Maximum retry attempts (default: 2, meaning 3 total attempts)
# MAX_RETRIES=2

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log directory (relative to project root)
LOG_DIR=logs

# ============================================================================
# Database Configuration (Future Use)
# ============================================================================
# MongoDB connection string
MONGO_URI=mongodb://localhost:27017

# Database name
DB_NAME=ai_chief_of_staff

# ============================================================================
# API Configuration
# ============================================================================
# API server host
API_HOST=0.0.0.0

# API server port
API_PORT=8000

# Enable API debug mode (not recommended for production)
API_DEBUG=false
